pipeline {
    agent any

    stages {
        stage('clone') {
            steps {
              git branch: 'main',https://github.com/CloudTechDevOps/docker_python_flask-project.git'
            }
        }
        stage('init') {
            steps {
                sh 'terraform init'
            }
        }
         stage('plan') {
            steps {
                sh 'terraform plan'
            }
        }
    }
}
